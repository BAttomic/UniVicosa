# Database
MONGODB_URI=mongodb://localhost:27017/ticketflow

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here-minimum-32-chars
NEXTAUTH_URL=http://localhost:3000

# JWT
JWT_SECRET=jwt-secret-key-here-minimum-32-chars

# Ticket QR rotation
TICKET_HMAC_SECRET=hmac-secret-key-here-minimum-16-chars

# Email (optional - defaults to console in dev)
RESEND_API_KEY=

# Payment (optional - for future Stripe integration)
STRIPE_SECRET_KEY=

# App
NODE_ENV=development
PORT=3000
